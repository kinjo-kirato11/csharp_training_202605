
@model WebEmployeeManagement.Infrastructures.Entities.Employee
@{
    ViewData["Title"] = "社員追加";
}

<h2>社員登録</h2>

@if (ViewBag.ErrorMessage != null)
{
    <p style="color:red;">@ViewBag.ErrorMessage</p>
}

<form asp-action="Create" method="post">
    <div class ="form-group">
        <label asp-for="EmployeeName">社員名</label>
        <input asp-for="EmployeeName" class="form-control" />
        <span asp-validation-for="EmployeeName" class="validation"></span>
    </div>
    <div class="form-group">
        <label asp-for="DepartmentId">部署名</label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control">
            <option value="">部署を選択してください</option>
        </select>
        <span asp-validation-for="DepartmentId" class="validation"></span>
    </div>
    <div class="button-area">
        <button type="submit" class="btn btn-primary">登録</button>
    </div>
</form>

<p><a asp-controller="Employees" asp-action="Index">社員一覧へ戻る</a></p>