@model List<EmployeeList.Models.Employee>
@{
    ViewData["Title"] = "社員一覧";
}

<h2>社員一覧</h2>
 <a asp-controller="Employees" asp-action="Create" class="btn btn-primary">社員登録</a>
  <a asp-controller="Home" asp-action="Index" class="btn btn-primary">ホーム</a>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>社員ID</th>
            <th>氏名</th>
            <th>部署ID</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var employee in Model)
    {
        <tr>
            <td>@employee.EmployeeId</td>
            <td>@employee.EmployeeName</td>
            <td>@employee.DepartmentId</td>
        </tr>
    }
    </tbody>
</table>